generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  partyId     String   @unique
  email       String?
  publicKey   String?
  appBalance  Decimal  @default(0) @db.Decimal(20, 8) // 8 decimal places = 1 satoshi precision
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deposits    Deposit[]
  bets        Bet[]
  withdrawals Withdrawal[]

  @@map("users")
}

model Market {
  id          String       @id @default(cuid())
  question    String       @db.VarChar(500)
  description String?      @db.VarChar(2000)
  category    String       @default("crypto") @db.VarChar(50)
  assetPair   String       @db.VarChar(20)
  startPrice  Decimal      @db.Decimal(20, 8)
  closePrice  Decimal?     @db.Decimal(20, 8)
  direction   String?      @db.VarChar(10)
  status      MarketStatus @default(OPEN)
  openAt      DateTime     @default(now())
  closeAt     DateTime
  settledAt   DateTime?
  totalUp     Decimal      @default(0) @db.Decimal(20, 8)
  totalDown   Decimal      @default(0) @db.Decimal(20, 8)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  bets        Bet[]

  @@map("markets")
}

model Bet {
  id        String    @id @default(cuid())
  userId    String
  marketId  String
  direction String    @db.VarChar(10)
  amount    Decimal   @db.Decimal(20, 8)
  payout    Decimal?  @db.Decimal(20, 8)
  status    BetStatus @default(PENDING)
  placedAt  DateTime  @default(now())
  settledAt DateTime?

  user   User   @relation(fields: [userId], references: [id])
  market Market @relation(fields: [marketId], references: [id])

  @@unique([userId, marketId]) // one bet per user per market — enforced at DB level
  @@map("bets")
}

model Deposit {
  id        String        @id @default(cuid())
  userId    String
  amount    Decimal       @db.Decimal(20, 8)
  txId      String?       @unique // contractId — dedup key, unique constraint prevents double-credit
  status    DepositStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("deposits")
}

model Withdrawal {
  id        String           @id @default(cuid())
  userId    String
  amount    Decimal          @db.Decimal(20, 8)
  txId      String?          @unique
  status    WithdrawalStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("withdrawals")
}

enum MarketStatus {
  OPEN
  CLOSED
  SETTLED
  CANCELLED
}

enum BetStatus {
  PENDING
  WON
  LOST
  REFUNDED
}

enum DepositStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum WithdrawalStatus {
  PENDING
  CONFIRMED
  FAILED
  FAILED_ROLLBACK // on-chain transfer failed AND DB rollback also failed — needs manual reconciliation
}
